# ─── Core Application ───
DATABASE_URL=postgresql://minibank:minibank@localhost:5432/minibank
JWT_SECRET=change-this-to-a-random-secret-in-production
PORT=3000
NODE_ENV=development

# ─── Splunk HEC Integration (optional) ───
# Set these to forward structured logs to Splunk in real-time.
# Logs are batched and sent every 2 seconds.
SPLUNK_HEC_URL=https://inputs.YOUR_INSTANCE.splunkcloud.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_INDEX=main
SPLUNK_SOURCE=minibank
SPLUNK_SOURCETYPE=_json

# ─── Grafana Cloud Integration (optional) ───
# Option 1 (recommended): Let Grafana scrape GET /metrics directly.
#   Configure in Grafana Cloud UI: Connections → Scrape endpoint → https://your-app.up.railway.app/metrics
#
# Option 2 (push): Set these to push metrics via remote write.
GRAFANA_REMOTE_WRITE_URL=https://prometheus-prod-01-eu-west-0.grafana.net/api/prom/push
GRAFANA_METRICS_USER=123456
GRAFANA_METRICS_TOKEN=your-grafana-cloud-api-token
